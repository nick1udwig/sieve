# -----------------------------
# Sieve v3 shared environment
# -----------------------------

# OpenAI API key (fallback used by planner/guidance/quarantine if scoped keys are unset)
OPENAI_API_KEY=
# ChatGPT Codex subscription overrides for `openai_codex` provider.
# If unset, Sieve falls back to `$SIEVE_HOME/state/auth.json` (or `SIEVE_OPENAI_CODEX_AUTH_JSON_PATH`).
# Use `cargo run -p sieve-app -- auth login openai-codex` to populate the auth file.
OPENAI_CODEX_ACCESS_TOKEN=
OPENAI_CODEX_ACCOUNT_ID=
SIEVE_OPENAI_CODEX_AUTH_JSON_PATH=

# Enable live OpenAI tests in `sieve-llm` (set to 1 to run live tests)
SIEVE_RUN_OPENAI_LIVE=0

# -----------------------------
# Planner model (P-LLM)
# Provider: `openai` or `openai_codex`
# -----------------------------
SIEVE_PLANNER_PROVIDER=openai
SIEVE_PLANNER_MODEL=gpt-4o-mini
# Optional custom API base, e.g. OpenAI-compatible gateway
SIEVE_PLANNER_API_BASE=
# Optional planner-specific key; falls back to OPENAI_API_KEY
SIEVE_PLANNER_OPENAI_API_KEY=

# -----------------------------
# Guidance model (Q-LLM -> planner typed signal channel)
# Provider: `openai` or `openai_codex`
# -----------------------------
# Optional override; falls back to SIEVE_PLANNER_* when unset.
SIEVE_GUIDANCE_PROVIDER=openai
SIEVE_GUIDANCE_MODEL=
SIEVE_GUIDANCE_API_BASE=
SIEVE_GUIDANCE_OPENAI_API_KEY=

# -----------------------------
# Brave search CLI credentials (for bash-based search flows)
# -----------------------------
# Exposed to bash commands; no dedicated `brave_search` tool is used.
BRAVE_API_KEY=
# Optional endpoint override for CLI/bash search commands.
SIEVE_BRAVE_API_BASE=https://api.search.brave.com/res/v1/web/search

# Voice-note I/O (Telegram)
# No env command template required: sieve-app runs `st stt` and `st tts` directly.
# Ensure `st` is installed and configured on host (`st providers` should list `openai`).

# -----------------------------
# Response writer model (R-LLM)
# Provider: `openai` or `openai_codex`
# -----------------------------
# Optional override; when unset, response writer reuses planner config + key.
SIEVE_RESPONSE_PROVIDER=openai
SIEVE_RESPONSE_MODEL=
SIEVE_RESPONSE_API_BASE=
SIEVE_RESPONSE_OPENAI_API_KEY=

# -----------------------------
# Quarantine model (Q-LLM)
# Provider: `openai` or `openai_codex`
# -----------------------------
# Used for on-demand summaries of untrusted output refs.
SIEVE_QUARANTINE_PROVIDER=openai
SIEVE_QUARANTINE_MODEL=gpt-4o-mini
# Optional custom API base
SIEVE_QUARANTINE_API_BASE=
# Optional quarantine-specific key; falls back to OPENAI_API_KEY
SIEVE_QUARANTINE_OPENAI_API_KEY=

# -----------------------------
# Telegram adapter
# -----------------------------
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=
# Numeric chat id (can be negative for groups/channels)
TELEGRAM_CHAT_ID=
# Optional CSV allowlist of Telegram sender user IDs (e.g. `12345,67890`)
# When unset/blank, any sender in `TELEGRAM_CHAT_ID` may prompt/approve (existing behavior)
SIEVE_TELEGRAM_ALLOWED_SENDER_USER_IDS=

# -----------------------------
# Integrated app entrypoint
# -----------------------------
# Base Sieve data dir (default: $HOME/.sieve)
SIEVE_HOME=
# Policy TOML path used by `cargo run -p sieve-app -- "<prompt>"`
SIEVE_POLICY_PATH=docs/policy/baseline-policy.toml
# CWD for shell execution/precheck
SIEVE_RUNTIME_CWD=.
# Comma-separated tool allowlist passed to planner turns
# Note: `brave_search` is intentionally ignored; use bash/CLI search commands instead.
SIEVE_ALLOWED_TOOLS=bash,endorse,declassify
# Unknown/uncertain command mode: ask | accept | deny
SIEVE_UNKNOWN_MODE=deny
SIEVE_UNCERTAIN_MODE=deny
# Long-running mode parallelism cap (used when no CLI prompt is passed)
SIEVE_MAX_CONCURRENT_TURNS=4
# Max planner act-observe iterations per user turn
SIEVE_MAX_PLANNER_STEPS=3
# Max quarantine summary-model calls per user turn (compose/evidence/gates)
SIEVE_MAX_SUMMARY_CALLS_PER_TURN=12
# LCM memory integration (dual lane: trusted + untrusted)
# Messages are ingested continuously, but planner retrieval is tool-driven via:
#   sieve-lcm-cli query --lane both --query "..." --json
# No automatic planner context injection from memory.
SIEVE_LCM_ENABLED=1
SIEVE_LCM_GLOBAL_SESSION_ID=global
SIEVE_LCM_TRUSTED_DB_PATH=
SIEVE_LCM_UNTRUSTED_DB_PATH=
# Optional override for CLI executable name/path.
SIEVE_LCM_CLI_BIN=sieve-lcm-cli
# Optional LLM provider exchange log path (JSONL). Default:
#   $SIEVE_HOME/logs/llm-provider-exchanges.jsonl
SIEVE_LLM_EXCHANGE_LOG_PATH=
# Telegram long-poll timeout in seconds
SIEVE_TELEGRAM_POLL_TIMEOUT_SECS=1
