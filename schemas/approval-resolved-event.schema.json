{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sieve.local/schemas/approval-resolved-event.schema.json",
  "title": "ApprovalResolvedEvent",
  "type": "object",
  "required": [
    "schema_version",
    "request_id",
    "run_id",
    "action",
    "created_at_ms"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "request_id": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "action": {
      "type": "string",
      "enum": ["approve_once", "approve_always", "deny"]
    },
    "created_at_ms": {
      "type": "integer",
      "minimum": 0
    }
  },
  "additionalProperties": false
}
